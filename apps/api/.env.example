# Copy to .env and fill in values. Never commit .env.

# PostgreSQL connection string (asyncpg driver, TCP connection required).
# On macOS with Homebrew Postgres, replace YOUR_USERNAME with your macOS username (run: whoami).
# If Postgres has no password set (default Homebrew install), omit the colon and password.
# Examples:
#   postgresql+asyncpg://raunak@localhost/signal_hub      (most common on macOS)
#   postgresql+asyncpg://postgres@localhost/signal_hub    (if using the postgres superuser)
DATABASE_URL=postgresql+asyncpg://YOUR_USERNAME@localhost/signal_hub

# Set to true to enable SQLAlchemy query logging
DEBUG=false

# Feature flags for experimental integrations
ENABLE_IMESSAGE=false
