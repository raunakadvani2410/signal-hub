# Copy to .env and fill in values. Never commit .env.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# asyncpg requires a TCP connection. Replace YOUR_USERNAME with your macOS
# username (run: whoami). Omit password if Homebrew Postgres has none set.
# Examples:
#   postgresql+asyncpg://raunak@localhost/signal_hub
#   postgresql+asyncpg://postgres@localhost/signal_hub
DATABASE_URL=postgresql+asyncpg://YOUR_USERNAME@localhost/signal_hub

# Set to true to enable SQLAlchemy query logging
DEBUG=false

# ── Token storage ─────────────────────────────────────────────────────────────
# Directory for OAuth token files. Relative to apps/api/ (where uvicorn runs).
# The .tokens/ directory is gitignored — tokens are never committed.
TOKEN_DIR=.tokens

# ── Gmail / Google OAuth ──────────────────────────────────────────────────────
# How to get these values:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project (or select an existing one)
#   3. APIs & Services → Enable APIs → enable "Gmail API"
#   4. APIs & Services → OAuth consent screen
#      - User type: External
#      - App name: anything (e.g. "Personal Command Center")
#      - Add your Gmail address as a test user
#   5. APIs & Services → Credentials → Create Credentials → OAuth client ID
#      - Application type: Web application
#      - Authorized redirect URIs: http://localhost:8000/api/gmail/callback
#   6. Copy the Client ID and Client Secret below
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/callback

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_IMESSAGE=false
